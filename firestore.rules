rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // First-time signup (create) may include tier:'free' only.
      // Updates may not touch Stripe-managed fields — those are written
      // exclusively by the server-side webhook via Admin SDK.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.tier == 'free'
        && !request.resource.data.keys().hasAny([
            'stripeCustomerId', 'stripeSubscriptionId',
            'stripeStatus', 'stripePriceId', 'currentPeriodEnd'
          ]);
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.keys().hasAny([
            'tier', 'stripeCustomerId', 'stripeSubscriptionId',
            'stripeStatus', 'stripePriceId', 'currentPeriodEnd'
          ]);

      match /activity/{activityId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if false;  // activity is append-only
      }

      match /results/{demoSlug} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
